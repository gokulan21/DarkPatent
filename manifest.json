{
  "manifest_version": 3,
  "name": "SecureGuard - Data Leak Prevention",
  "version": "1.0.0",
  "description": "Monitors all form fields across every website and alerts you when sensitive data is detected.",
  "permissions": [
    "storage",
    "activeTab",
    "webRequest",
    "declarativeNetRequest",
    "notifications",
    "tabs",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://haveibeenpwned.com/*",
    "https://safebrowsing.googleapis.com/*",
    "https://www.phishtank.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SecureGuard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}